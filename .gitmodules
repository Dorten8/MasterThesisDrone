[submodule "mavlink-router"]
	path = mavlink-router
	url = https://github.com/mavlink-router/mavlink-router.git
[submodule "src/mocap"]
	path = src/mocap
	url = https://github.com/Dorten8/mocap.git
[submodule "src/mocap_px4_bridge"]
	path = src/mocap_px4_bridge
	url = https://github.com/SaxionMechatronics/mocap_px4_bridge.git
[submodule "src/px4_msgs"]
	path = src/px4_msgs
	url = https://github.com/SaxionMechatronics/px4_msgs.git
[submodule "src/micro-ROS-Agent"]
	path = src/micro-ROS-Agent
	url = https://github.com/micro-ROS/micro-ROS-Agent.git
	branch = humble
[submodule "src/object-tracking-"]
	path = src/object-tracking-
	url = https://github.com/Dorten8/object-tracking-.git
[submodule "src/PX4-Autopilot"]
	path = src/PX4-Autopilot
	url = https://github.com/PX4/PX4-Autopilot.git
[submodule "src/Micro-XRCE-DDS-Agent"]
	path = src/Micro-XRCE-DDS-Agent
	url = https://github.com/eProsima/Micro-XRCE-DDS-Agent.git
