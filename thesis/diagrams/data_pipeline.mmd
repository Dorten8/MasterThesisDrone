    style Phase0 fill:#f5f5f5,stroke:#ccc,stroke-width:1px
    style Phase1 fill:#f0f8ff,stroke:#3498db,stroke-width:1px
    style Phase2 fill:#f0f8ff,stroke:#3498db,stroke-width:1px
    style Phase3 fill:#f0f8ff,stroke:#3498db,stroke-width:1px
    style Phase4 fill:#fff8f0,stroke:#e67e22,stroke-width:1px
    style Phase5 fill:#f0fff0,stroke:#2ecc71,stroke-width:1px
    style Phase6 fill:#faf0ff,stroke:#9b59b6,stroke-width:1px
    style Gates fill:#fffdf5,stroke:#f39c12,stroke-width:1px
