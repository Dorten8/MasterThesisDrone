&lt;br&gt;• Geofence breached&lt;br&gt;• Spacebar kill-switch&lt;br&gt;• Low battery (&amp;lt;20.4 V)&lt;/span&gt;" style="text=html;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#b85450;align=left;verticalAlign=middle;whiteSpace=wrap;labelBackgroundColor=none" vertex="1"><mxGeometry x="875" y="303" width="135" height="65" as="geometry" /></mxCell><mxCell id="136" parent="1" value="&lt;span style=&quot;font-size:10px;color:#888&quot;&gt;Each loop = 1 data pass&lt;br&gt;Max ~8–12 passes per battery&lt;/span&gt;" style="text=html;html=1;fontSize=10;fontFamily=Helvetica;fontColor=#888;align=center;verticalAlign=middle;whiteSpace=wrap;labelBackgroundColor=none" vertex="1"><mxGeometry x="735" y="483" width="130" height="28" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>