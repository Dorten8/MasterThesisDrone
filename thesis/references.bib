@article{lercheSpinFlyUAVSystem,
  title = {{{SpinFly}}: {{UAV System}} for {{Active Inspection}} in the {{Pharmaceutical Industry}}},
  author = {Lerche, Alexander Niclas and Faina, Andres},
  abstract = {Inspecting confined, GPS-denied environments within the pharmaceutical industry presents significant challenges for safety, efficiency, and data quality using traditional methods or existing Unmanned Aerial Vehicles (UAVs). This thesis investigates the development of SpinFly, a UAV system designed to address these challenges by integrating a protective structure with sensing capabilities for active inspection. SpinFly, built upon an open-source platform, features a 3D-printed hybrid PETG-TPU frame with a rotational outer shell coupled to a magnetic encoder, enabling contact-based odometry and enhanced collision resilience. Experimental drop tests demonstrated the system’s structural robustness, with the SpinFly drone withstanding repeated impacts from heights up to 200 cm without structural failure. Wall navigation tests, while hindered by flight instability and reliance on manual control, indicated that the magnetic encoder provided more consistent relative positional tracking along surfaces compared to the onboard IMU, though accurate long-distance traversal proved challenging due to intermittent wall contact. The findings suggest that leveraging a protective structure as an active sensing element is a feasible approach for UAVs in complex environments. However, realizing the full potential of SpinFly requires further development in flight stability, autonomous control, and sensor integration to overcome current limitations.},
  langid = {english},
  file = {/home/dorten/Zotero/storage/Z66Z4XEL/Lerche and Faina - SpinFly UAV System for Active Inspection in the Pharmaceutical Industry.pdf}
}

